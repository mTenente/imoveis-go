<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ImóveisGO — Extrator de Lançamentos</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600;700&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #f7f4ef;
  --surface: #ffffff;
  --surface2: #f0ece4;
  --border: #e0d9ce;
  --text: #1a1714;
  --muted: #8a8078;
  --gold: #b8882a;
  --gold2: #d4a843;
  --green: #2d6a4f;
  --red: #c0392b;
  --radius: 14px;
  --shadow: 0 2px 20px rgba(0,0,0,0.07);
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Outfit', sans-serif;
  min-height: 100vh;
}

/* HEADER */
header {
  background: var(--text);
  padding: 20px 48px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.logo {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.6rem;
  font-weight: 700;
  color: #f7f4ef;
  letter-spacing: 0.5px;
}

.logo span { color: var(--gold2); }

.header-sub {
  font-size: 0.78rem;
  color: #8a8078;
  letter-spacing: 1px;
  text-transform: uppercase;
}

/* MAIN */
.container {
  max-width: 900px;
  margin: 0 auto;
  padding: 48px 24px;
}

/* API KEY */
.api-section {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 24px 28px;
  margin-bottom: 28px;
  box-shadow: var(--shadow);
  display: flex;
  gap: 16px;
  align-items: flex-end;
}

.api-section .field { flex: 1; }

label {
  display: block;
  font-size: 0.72rem;
  font-weight: 600;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 8px;
}

input[type="password"], input[type="text"], select, textarea {
  width: 100%;
  background: var(--bg);
  border: 1.5px solid var(--border);
  border-radius: 10px;
  padding: 11px 16px;
  color: var(--text);
  font-family: 'Outfit', sans-serif;
  font-size: 0.9rem;
  outline: none;
  transition: border-color 0.2s;
}

input:focus, select:focus, textarea:focus { border-color: var(--gold); }

.btn {
  background: var(--text);
  color: var(--bg);
  border: none;
  border-radius: 10px;
  padding: 11px 24px;
  font-family: 'Outfit', sans-serif;
  font-weight: 600;
  font-size: 0.88rem;
  cursor: pointer;
  transition: background 0.2s, transform 0.1s;
  white-space: nowrap;
}

.btn:hover { background: #333; transform: translateY(-1px); }
.btn:active { transform: translateY(0); }
.btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

.btn-gold {
  background: var(--gold);
  color: white;
}
.btn-gold:hover { background: var(--gold2); }

.btn-green {
  background: var(--green);
  color: white;
}
.btn-green:hover { background: #246040; }

/* UPLOAD ZONE */
.upload-zone {
  background: var(--surface);
  border: 2px dashed var(--border);
  border-radius: var(--radius);
  padding: 48px 32px;
  text-align: center;
  cursor: pointer;
  transition: all 0.2s;
  margin-bottom: 28px;
  box-shadow: var(--shadow);
}

.upload-zone:hover, .upload-zone.dragover {
  border-color: var(--gold);
  background: #fffaf2;
}

.upload-icon { font-size: 2.5rem; margin-bottom: 12px; }

.upload-zone h3 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.4rem;
  font-weight: 700;
  margin-bottom: 8px;
  color: var(--text);
}

.upload-zone p {
  font-size: 0.88rem;
  color: var(--muted);
  margin-bottom: 20px;
}

#fileInput { display: none; }

/* FILE LIST */
.file-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 28px;
}

.file-item {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 14px 18px;
  display: flex;
  align-items: center;
  gap: 14px;
  box-shadow: var(--shadow);
  animation: slideIn 0.2s ease;
}

@keyframes slideIn {
  from { opacity: 0; transform: translateY(-8px); }
  to { opacity: 1; transform: translateY(0); }
}

.file-icon { font-size: 1.4rem; flex-shrink: 0; }

.file-info { flex: 1; min-width: 0; }
.file-name {
  font-weight: 500;
  font-size: 0.9rem;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.file-size { font-size: 0.78rem; color: var(--muted); margin-top: 2px; }

.file-status {
  font-size: 0.78rem;
  padding: 4px 10px;
  border-radius: 100px;
  font-weight: 500;
  flex-shrink: 0;
}

.status-waiting { background: #f0ece4; color: var(--muted); }
.status-processing { background: #fff8e6; color: var(--gold); }
.status-done { background: #e8f5ee; color: var(--green); }
.status-error { background: #fde8e8; color: var(--red); }

.file-remove {
  background: none;
  border: none;
  color: var(--muted);
  cursor: pointer;
  font-size: 1rem;
  padding: 4px;
  transition: color 0.2s;
  flex-shrink: 0;
}
.file-remove:hover { color: var(--red); }

/* ACTIONS BAR */
.actions-bar {
  display: flex;
  gap: 12px;
  margin-bottom: 32px;
  flex-wrap: wrap;
}

/* RESULTS */
.results-section { display: none; }
.results-section.visible { display: block; }

.results-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20px;
  flex-wrap: gap;
  gap: 12px;
}

.results-header h2 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.6rem;
  font-weight: 700;
}

.export-btns { display: flex; gap: 10px; }

/* CARD RESULTADO */
.result-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  margin-bottom: 20px;
  box-shadow: var(--shadow);
  overflow: hidden;
  animation: slideIn 0.3s ease;
}

.result-card-header {
  background: var(--text);
  color: var(--bg);
  padding: 16px 24px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.result-card-header h3 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.2rem;
  font-weight: 600;
}

.result-source {
  font-size: 0.75rem;
  color: #8a8078;
  display: flex;
  align-items: center;
  gap: 6px;
}

.result-body { padding: 24px; }

.result-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 16px;
  margin-bottom: 20px;
}

.result-field {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 12px 16px;
}

.result-field label {
  color: var(--muted);
  font-size: 0.7rem;
  margin-bottom: 6px;
  letter-spacing: 0.8px;
}

.result-field input, .result-field select {
  background: transparent;
  border: none;
  padding: 0;
  font-size: 0.92rem;
  font-weight: 500;
  color: var(--text);
  width: 100%;
}

.result-field input:focus, .result-field select:focus {
  outline: none;
  border: none;
}

/* PLANTAS */
.plantas-section { margin-top: 16px; }

.plantas-section h4 {
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 12px;
}

.plantas-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 10px;
}

.planta-card {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 12px 14px;
  display: grid;
  grid-template-columns: 1fr 1fr 1fr auto;
  gap: 8px;
  align-items: center;
}

.planta-card input {
  background: transparent;
  border: none;
  padding: 4px 0;
  font-size: 0.85rem;
  color: var(--text);
  font-family: 'Outfit', sans-serif;
  width: 100%;
}

.planta-card input:focus { outline: none; border-bottom: 1px solid var(--gold); }

.planta-remove {
  background: none;
  border: none;
  color: var(--muted);
  cursor: pointer;
  font-size: 0.9rem;
  padding: 2px;
}
.planta-remove:hover { color: var(--red); }

.btn-add-planta {
  background: none;
  border: 1.5px dashed var(--border);
  border-radius: 8px;
  padding: 8px;
  color: var(--muted);
  font-family: 'Outfit', sans-serif;
  font-size: 0.82rem;
  cursor: pointer;
  width: 100%;
  transition: all 0.2s;
  margin-top: 8px;
}

.btn-add-planta:hover { border-color: var(--gold); color: var(--gold); }

/* OBSERVACOES */
.obs-field { margin-top: 16px; }
.obs-field textarea {
  resize: vertical;
  min-height: 80px;
  font-size: 0.88rem;
}

/* PROGRESS */
.progress-bar-wrap {
  background: var(--border);
  border-radius: 100px;
  height: 4px;
  margin-top: 8px;
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  background: var(--gold);
  border-radius: 100px;
  transition: width 0.3s;
  width: 0%;
}

/* LOADING SPINNER */
.spinner {
  width: 18px; height: 18px;
  border: 2px solid rgba(255,255,255,0.3);
  border-top-color: white;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
  display: inline-block;
  vertical-align: middle;
  margin-right: 6px;
}

@keyframes spin { to { transform: rotate(360deg); } }

/* TOAST */
.toast {
  position: fixed;
  bottom: 24px;
  right: 24px;
  background: var(--text);
  color: var(--bg);
  padding: 14px 20px;
  border-radius: 10px;
  font-size: 0.88rem;
  font-weight: 500;
  box-shadow: 0 8px 24px rgba(0,0,0,0.2);
  transform: translateY(80px);
  opacity: 0;
  transition: all 0.3s;
  z-index: 999;
  max-width: 320px;
}

.toast.show { transform: translateY(0); opacity: 1; }
.toast.success { background: var(--green); }
.toast.error { background: var(--red); }

/* EMPTY */
.empty-results {
  text-align: center;
  padding: 48px;
  color: var(--muted);
}

/* PLANTA HEADER */
.planta-header {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr auto;
  gap: 8px;
  padding: 0 14px;
  margin-bottom: 4px;
}

.planta-header span {
  font-size: 0.68rem;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 0.8px;
  font-weight: 600;
}

@media (max-width: 600px) {
  header { padding: 16px 20px; }
  .container { padding: 24px 16px; }
  .api-section { flex-direction: column; }
  .result-grid { grid-template-columns: 1fr 1fr; }
  .planta-card { grid-template-columns: 1fr 1fr; }
}
</style>
</head>
<body>

<header>
  <div class="logo">Imóveis<span>GO</span></div>
  <div class="header-sub">Extrator de Lançamentos</div>
</header>

<div class="container">

  <!-- API KEY -->
  <div class="api-section">
    <div class="field">
      <label>Chave da API Anthropic</label>
      <input type="password" id="apiKey" placeholder="sk-ant-..." autocomplete="off">
    </div>
    <button class="btn" onclick="salvarChave()">Salvar</button>
  </div>

  <!-- UPLOAD -->
  <div class="upload-zone" id="uploadZone" onclick="document.getElementById('fileInput').click()">
    <div class="upload-icon">📄</div>
    <h3>Solte os PDFs aqui</h3>
    <p>Books digitais, cadernos de plantas, tabelas de preço — qualquer material do lançamento</p>
    <button class="btn btn-gold" onclick="event.stopPropagation(); document.getElementById('fileInput').click()">
      Selecionar arquivos
    </button>
    <input type="file" id="fileInput" multiple accept=".pdf,image/*">
  </div>

  <!-- FILE LIST -->
  <div class="file-list" id="fileList"></div>

  <!-- ACTIONS -->
  <div class="actions-bar" id="actionsBar" style="display:none">
    <button class="btn btn-gold" id="btnProcessar" onclick="processarTodos()">
      ✨ Extrair informações com IA
    </button>
    <button class="btn" onclick="limparTudo()">Limpar tudo</button>
  </div>

  <!-- PROGRESS -->
  <div id="progressWrap" style="display:none; margin-bottom:20px;">
    <div style="font-size:0.85rem; color:var(--muted); margin-bottom:6px;" id="progressLabel">Processando...</div>
    <div class="progress-bar-wrap"><div class="progress-bar" id="progressBar"></div></div>
  </div>

  <!-- RESULTS -->
  <div class="results-section" id="resultsSection">
    <div class="results-header">
      <h2>Empreendimentos extraídos</h2>
      <div class="export-btns">
        <button class="btn btn-green" onclick="exportarJSON()">⬇ Exportar JSON</button>
        <button class="btn" onclick="exportarCSV()">⬇ Exportar CSV</button>
      </div>
    </div>
    <div id="resultsList"></div>
  </div>

</div>

<div class="toast" id="toast"></div>

<script>
// =============================================
// ESTADO
// =============================================
let arquivos = [];
let resultados = [];

// =============================================
// API KEY
// =============================================
function salvarChave() {
  const key = document.getElementById('apiKey').value.trim();
  if (!key.startsWith('sk-ant-')) {
    showToast('Chave inválida. Deve começar com sk-ant-', 'error');
    return;
  }
  localStorage.setItem('anthropic_key', key);
  showToast('Chave salva com sucesso!', 'success');
}

function getKey() {
  return document.getElementById('apiKey').value.trim() || localStorage.getItem('anthropic_key') || '';
}

// =============================================
// UPLOAD
// =============================================
const uploadZone = document.getElementById('uploadZone');
const fileInput = document.getElementById('fileInput');

uploadZone.addEventListener('dragover', e => { e.preventDefault(); uploadZone.classList.add('dragover'); });
uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('dragover'));
uploadZone.addEventListener('drop', e => {
  e.preventDefault();
  uploadZone.classList.remove('dragover');
  adicionarArquivos([...e.dataTransfer.files]);
});

fileInput.addEventListener('change', () => adicionarArquivos([...fileInput.files]));

function adicionarArquivos(novos) {
  const validos = novos.filter(f => f.type === 'application/pdf' || f.type.startsWith('image/'));
  validos.forEach(f => {
    if (!arquivos.find(a => a.file.name === f.name)) {
      arquivos.push({ file: f, status: 'waiting', id: Date.now() + Math.random() });
    }
  });
  renderFileList();
  document.getElementById('actionsBar').style.display = arquivos.length > 0 ? 'flex' : 'none';
  fileInput.value = '';
}

function removerArquivo(id) {
  arquivos = arquivos.filter(a => a.id !== id);
  renderFileList();
  document.getElementById('actionsBar').style.display = arquivos.length > 0 ? 'flex' : 'none';
}

function renderFileList() {
  const list = document.getElementById('fileList');
  list.innerHTML = arquivos.map(a => `
    <div class="file-item" id="file-${a.id}">
      <div class="file-icon">${a.file.type === 'application/pdf' ? '📄' : '🖼️'}</div>
      <div class="file-info">
        <div class="file-name">${a.file.name}</div>
        <div class="file-size">${formatSize(a.file.size)}</div>
      </div>
      <span class="file-status status-${a.status}">${statusLabel(a.status)}</span>
      ${a.status === 'waiting' ? `<button class="file-remove" onclick="removerArquivo(${a.id})">✕</button>` : ''}
    </div>
  `).join('');
}

function statusLabel(s) {
  return { waiting: 'Aguardando', processing: '⏳ Processando', done: '✓ Concluído', error: '✗ Erro' }[s] || s;
}

function formatSize(bytes) {
  if (bytes < 1024) return bytes + ' B';
  if (bytes < 1024*1024) return (bytes/1024).toFixed(1) + ' KB';
  return (bytes/(1024*1024)).toFixed(1) + ' MB';
}

// =============================================
// PROCESSAR
// =============================================
async function processarTodos() {
  const key = getKey();
  if (!key) {
    showToast('Insira sua chave da API Anthropic primeiro', 'error');
    return;
  }

  const btn = document.getElementById('btnProcessar');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner"></span> Processando...';

  const progressWrap = document.getElementById('progressWrap');
  const progressBar = document.getElementById('progressBar');
  const progressLabel = document.getElementById('progressLabel');
  progressWrap.style.display = 'block';

  const pendentes = arquivos.filter(a => a.status === 'waiting');

  for (let i = 0; i < pendentes.length; i++) {
    const arq = pendentes[i];
    progressLabel.textContent = `Processando ${i+1} de ${pendentes.length}: ${arq.file.name}`;
    progressBar.style.width = `${((i) / pendentes.length) * 100}%`;

    arq.status = 'processing';
    renderFileList();

    try {
      const resultado = await extrairComIA(arq.file, key);
      resultado._arquivo = arq.file.name;
      resultado._id = arq.id;
      resultados.push(resultado);
      arq.status = 'done';
    } catch(e) {
      arq.status = 'error';
      console.error(e);
    }
    renderFileList();
  }

  progressBar.style.width = '100%';
  progressLabel.textContent = `✓ Concluído — ${resultados.length} empreendimento(s) extraído(s)`;

  btn.disabled = false;
  btn.innerHTML = '✨ Extrair informações com IA';

  renderResultados();
  document.getElementById('resultsSection').classList.add('visible');
  showToast(`${resultados.length} empreendimento(s) extraído(s) com sucesso!`, 'success');
}

async function extrairComIA(file, apiKey) {
  // Converte arquivo para base64
  const base64 = await fileToBase64(file);
  const isPDF = file.type === 'application/pdf';

  const prompt = `Você é um assistente especializado em mercado imobiliário brasileiro, especialmente em Goiânia.
Analise este material de lançamento imobiliário e extraia todas as informações disponíveis.

Retorne APENAS um JSON válido com esta estrutura (sem texto antes ou depois):
{
  "nome_empreendimento": "Nome do empreendimento",
  "incorporadora": "Nome da incorporadora",
  "setor": "Setor ou bairro em Goiânia",
  "endereco": "Endereço completo se disponível",
  "status": "Lançamento | Em obras | Pronto para morar",
  "entrega_prevista": "Mês/Ano de entrega",
  "andares": número ou null,
  "unidades_total": número ou null,
  "diferenciais": "Principais diferenciais do empreendimento",
  "plantas": [
    {
      "tipologia": "Ex: Studio, 2 Quartos, 3 Suítes",
      "quartos": número,
      "suites": número ou 0,
      "metragem_min": número em m² ou null,
      "metragem_max": número em m² ou null,
      "preco_min": número em reais ou null,
      "preco_max": número em reais ou null,
      "vagas": número ou null
    }
  ],
  "observacoes": "Outras informações relevantes"
}

Se uma informação não estiver disponível, use null. Extraia TODAS as tipologias de plantas encontradas.`;

  const content = isPDF
    ? [{ type: "document", source: { type: "base64", media_type: "application/pdf", data: base64 } }, { type: "text", text: prompt }]
    : [{ type: "image", source: { type: "base64", media_type: file.type, data: base64 } }, { type: "text", text: prompt }];

  const response = await fetch("https://api.anthropic.com/v1/messages", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      model: "claude-sonnet-4-20250514",
      max_tokens: 1000,
      messages: [{ role: "user", content }]
    })
  });

  if (!response.ok) {
    const err = await response.json();
    throw new Error(err.error?.message || 'Erro na API');
  }

  const data = await response.json();
  const text = data.content[0].text;
  const clean = text.replace(/```json|```/g, '').trim();
  return JSON.parse(clean);
}

function fileToBase64(file) {
  return new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.onload = () => resolve(reader.result.split(',')[1]);
    reader.onerror = reject;
    reader.readAsDataURL(file);
  });
}

// =============================================
// RENDER RESULTADOS
// =============================================
function renderResultados() {
  const list = document.getElementById('resultsList');

  if (resultados.length === 0) {
    list.innerHTML = '<div class="empty-results">Nenhum resultado ainda.</div>';
    return;
  }

  list.innerHTML = resultados.map((r, idx) => `
    <div class="result-card" id="card-${idx}">
      <div class="result-card-header">
        <h3>${r.nome_empreendimento || 'Empreendimento ' + (idx+1)}</h3>
        <span class="result-source">📄 ${r._arquivo}</span>
      </div>
      <div class="result-body">
        <div class="result-grid">
          ${campo('Incorporadora', r.incorporadora, idx, 'incorporadora')}
          ${campo('Setor / Bairro', r.setor, idx, 'setor')}
          ${campo('Endereço', r.endereco, idx, 'endereco')}
          ${campoSelect('Status', r.status, idx, 'status', ['Lançamento','Em obras','Pronto para morar'])}
          ${campo('Previsão de entrega', r.entrega_prevista, idx, 'entrega_prevista')}
          ${campo('Andares', r.andares, idx, 'andares')}
          ${campo('Total de unidades', r.unidades_total, idx, 'unidades_total')}
        </div>

        ${r.diferenciais ? `<div style="background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:12px 16px;margin-bottom:16px;font-size:0.88rem;color:var(--muted);">
          <strong style="color:var(--text);">✨ Diferenciais:</strong> ${r.diferenciais}
        </div>` : ''}

        <div class="plantas-section">
          <h4>🗺 Tipologias / Plantas</h4>
          <div class="planta-header">
            <span>Tipologia</span><span>m²</span><span>Preço</span><span></span>
          </div>
          <div class="plantas-grid" id="plantas-${idx}">
            ${(r.plantas || []).map((p, pi) => plantaHTML(idx, pi, p)).join('')}
          </div>
          <button class="btn-add-planta" onclick="adicionarPlanta(${idx})">+ Adicionar tipologia</button>
        </div>

        <div class="obs-field">
          <label>Observações</label>
          <textarea onchange="resultados[${idx}].observacoes = this.value">${r.observacoes || ''}</textarea>
        </div>
      </div>
    </div>
  `).join('');
}

function campo(label, valor, idx, campo) {
  return `<div class="result-field">
    <label>${label}</label>
    <input type="text" value="${valor || ''}" placeholder="—"
      onchange="resultados[${idx}]['${campo}'] = this.value">
  </div>`;
}

function campoSelect(label, valor, idx, campo, opcoes) {
  return `<div class="result-field">
    <label>${label}</label>
    <select onchange="resultados[${idx}]['${campo}'] = this.value">
      ${opcoes.map(o => `<option ${o === valor ? 'selected' : ''}>${o}</option>`).join('')}
    </select>
  </div>`;
}

function plantaHTML(idx, pi, p) {
  return `<div class="planta-card" id="planta-${idx}-${pi}">
    <input type="text" value="${p.tipologia || ''}" placeholder="Ex: 2 Quartos"
      onchange="resultados[${idx}].plantas[${pi}].tipologia = this.value">
    <input type="text" value="${p.metragem_min ? p.metragem_min + (p.metragem_max && p.metragem_max !== p.metragem_min ? '-'+p.metragem_max : '') + 'm²' : ''}"
      placeholder="Ex: 65m²"
      onchange="resultados[${idx}].plantas[${pi}].metragem_min = this.value">
    <input type="text" value="${p.preco_min ? 'R$ ' + Number(p.preco_min).toLocaleString('pt-BR') : ''}"
      placeholder="Ex: R$ 450.000"
      onchange="resultados[${idx}].plantas[${pi}].preco_min = this.value">
    <button class="planta-remove" onclick="removerPlanta(${idx}, ${pi})">✕</button>
  </div>`;
}

function adicionarPlanta(idx) {
  if (!resultados[idx].plantas) resultados[idx].plantas = [];
  resultados[idx].plantas.push({ tipologia: '', metragem_min: null, preco_min: null });
  renderResultados();
}

function removerPlanta(idx, pi) {
  resultados[idx].plantas.splice(pi, 1);
  renderResultados();
}

// =============================================
// EXPORT
// =============================================
function exportarJSON() {
  const dados = resultados.map(r => {
    const { _arquivo, _id, ...rest } = r;
    return rest;
  });
  const blob = new Blob([JSON.stringify(dados, null, 2)], { type: 'application/json' });
  download(blob, 'lancamentos-goiania.json');
  showToast('JSON exportado!', 'success');
}

function exportarCSV() {
  const linhas = [['Empreendimento','Incorporadora','Setor','Endereço','Status','Entrega','Tipologia','Quartos','Suítes','m² Min','m² Max','Preço Min','Preço Max','Vagas']];

  resultados.forEach(r => {
    const plantas = r.plantas || [{}];
    plantas.forEach(p => {
      linhas.push([
        r.nome_empreendimento || '',
        r.incorporadora || '',
        r.setor || '',
        r.endereco || '',
        r.status || '',
        r.entrega_prevista || '',
        p.tipologia || '',
        p.quartos || '',
        p.suites || '',
        p.metragem_min || '',
        p.metragem_max || '',
        p.preco_min || '',
        p.preco_max || '',
        p.vagas || ''
      ]);
    });
  });

  const csv = linhas.map(l => l.map(v => `"${String(v).replace(/"/g,'""')}"`).join(',')).join('\n');
  const blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8;' });
  download(blob, 'lancamentos-goiania.csv');
  showToast('CSV exportado!', 'success');
}

function download(blob, nome) {
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = nome;
  a.click();
  URL.revokeObjectURL(url);
}

// =============================================
// UTILS
// =============================================
function limparTudo() {
  arquivos = [];
  resultados = [];
  renderFileList();
  document.getElementById('actionsBar').style.display = 'none';
  document.getElementById('resultsSection').classList.remove('visible');
  document.getElementById('progressWrap').style.display = 'none';
}

function showToast(msg, type = '') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast show ' + type;
  setTimeout(() => t.className = 'toast', 3500);
}

